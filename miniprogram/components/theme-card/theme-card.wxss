.theme-display {
  overflow: hidden;
  margin-bottom: 24rpx;
}

.display-stage {
  min-height: 280rpx;
  padding: 36rpx 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.display-glyph {
  font-size: 128rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.86);
  font-weight: 600;
}

.display-summary {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.7;
}

.theme-content {
  padding: 28rpx;
}

.theme-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.theme-desc {
  color: #6f6a5f;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.mission-label {
  font-size: 24rpx;
  color: #7f7a6f;
  margin-bottom: 12rpx;
}

.mission-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
  background: #f9f6f0;
}

.mission-order {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #5a5a40;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

.mission-text {
  flex: 1;
  line-height: 1.7;
}

.theme-start-btn {
  margin-top: 24rpx;
}
