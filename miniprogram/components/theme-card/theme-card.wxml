<view wx:if="{{theme}}" class="theme-card" style="padding: 32rpx; border-top: 10rpx solid {{theme.vibeColor || '#5a5a40'}};">
  <view class="meta-row" style="margin-bottom: 16rpx;">
    <view class="meta-pill">{{theme.category || '主题'}}</view>
    <view class="meta-pill">{{theme.locationName || '当前位置'}}</view>
  </view>
  <view style="font-size: 40rpx; font-weight: 600; margin-bottom: 16rpx;">{{theme.title}}</view>
  <view style="color: #6f6a5f; line-height: 1.7; margin-bottom: 24rpx;">{{theme.description}}</view>
  <view wx:for="{{theme.missions}}" wx:key="index" class="mission-card" style="padding: 20rpx; margin-bottom: 14rpx; background: #f9f6f0;">
    {{index + 1}}. {{item}}
  </view>
  <button class="primary-btn" bindtap="handleStart" style="margin-top: 24rpx;">开始记录这次漫步</button>
</view>
