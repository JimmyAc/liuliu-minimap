<view wx:if="{{theme}}" class="theme-card theme-display" style="border-top: 10rpx solid {{theme.vibeColor || '#5a5a40'}};">
  <view class="display-stage" style="background: linear-gradient(135deg, {{theme.vibeColor || '#5a5a40'}} 0%, #f1eadf 100%);">
    <view class="display-glyph">{{theme.displayGlyph || '遛'}}</view>
    <view class="display-summary">{{displaySummary}}</view>
  </view>
  <view class="theme-content">
    <view class="meta-row" style="margin-bottom: 16rpx;">
      <view class="meta-pill">{{theme.category || '主题'}}</view>
      <view class="meta-pill">{{modeLabel}}</view>
      <view class="meta-pill">{{theme.locationName || '当前位置'}}</view>
    </view>
    <view class="theme-title">{{theme.title}}</view>
    <view class="theme-desc">{{theme.description}}</view>
    <view class="mission-label">今日任务</view>
    <view wx:for="{{theme.missions}}" wx:key="index" class="mission-card mission-item">
      <view class="mission-order">{{index + 1}}</view>
      <view class="mission-text">{{item}}</view>
    </view>
    <button class="primary-btn theme-start-btn" bindtap="handleStart">开始这次漫步</button>
  </view>
</view>
