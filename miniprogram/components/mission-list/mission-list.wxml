<view>
  <view wx:for="{{missionCards}}" wx:key="mission" class="mission-card mission-entry {{item.active ? 'mission-entry-active' : ''}}" bindtap="selectMission" data-mission="{{item.mission}}">
    <view class="mission-topline">
      <view class="mission-maintext" style="color: {{item.completed ? '#8f897e' : '#1a1a1a'}}; text-decoration: {{item.completed ? 'line-through' : 'none'}};">
        {{item.mission}}
      </view>
      <view class="meta-pill">{{item.completed ? '已完成' : (item.review ? '已核验' : '待打卡')}}</view>
    </view>
    <view wx:if="{{item.review}}" class="mission-review" style="color: {{item.review.passed ? '#4f6d45' : '#8a6a52'}};">
      {{item.review.comment}}
    </view>
    <view class="mission-actions">
      <view class="mission-tip">
        {{item.active ? '当前核验任务' : '点击切换到此任务'}}
      </view>
      <view class="mission-buttons">
        <button class="ghost-btn" size="mini" catchtap="toggleMission" data-mission="{{item.mission}}">{{item.completed ? '取消完成' : '勾选完成'}}</button>
        <button class="ghost-btn" size="mini" catchtap="verifyMission" data-mission="{{item.mission}}">打卡记录</button>
      </view>
    </view>
  </view>
</view>
