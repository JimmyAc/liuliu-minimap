<view>
  <view wx:for="{{missionCards}}" wx:key="mission" class="mission-card" style="padding: 22rpx; margin-bottom: 14rpx; border: {{item.active ? '2rpx solid #5a5a40' : '1rpx solid #ece5d9'}};" bindtap="selectMission" data-mission="{{item.mission}}">
    <view style="display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-bottom: 12rpx;">
      <view style="flex: 1; color: {{item.completed ? '#8f897e' : '#1a1a1a'}}; text-decoration: {{item.completed ? 'line-through' : 'none'}};">
        {{item.mission}}
      </view>
      <view class="meta-pill">{{item.completed ? '已完成' : (item.review ? '已核验' : '待打卡')}}</view>
    </view>
    <view wx:if="{{item.review}}" style="font-size: 22rpx; color: {{item.review.passed ? '#4f6d45' : '#8a6a52'}}; line-height: 1.6; margin-bottom: 12rpx;">
      {{item.review.comment}}
    </view>
    <view style="display: flex; justify-content: space-between; align-items: center; gap: 16rpx;">
      <view style="font-size: 22rpx; color: #7f7a6f;">
        {{item.active ? '当前核验任务' : '点击切换到此任务'}}
      </view>
      <button class="ghost-btn" size="mini" catchtap="verifyMission" data-mission="{{item.mission}}">核验打卡</button>
    </view>
  </view>
</view>
