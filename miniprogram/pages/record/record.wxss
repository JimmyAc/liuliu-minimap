.record-hero,
.section-block {
  margin-bottom: 24rpx;
}

.record-stage {
  padding: 32rpx;
  min-height: 260rpx;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.record-stage-glyph {
  font-size: 120rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.record-stage-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.record-stage-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.record-stage-desc {
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.7;
}

.record-body {
  padding: 28rpx;
}

.section-heading {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.mini-action {
  padding: 18rpx 24rpx;
  font-size: 24rpx;
}

.map-shell,
.record-panel {
  margin-top: 8rpx;
}

.active-task-card {
  background: #f9f6f0;
  border-radius: 22rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 18rpx;
}

.active-task-text {
  font-size: 30rpx;
  line-height: 1.7;
}

.media-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.media-actions button {
  flex: 1;
}

.media-group {
  margin-top: 20rpx;
}

.media-scroll {
  display: flex;
  gap: 16rpx;
}

.media-thumb {
  position: relative;
}

.media-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
}

.media-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  padding: 10rpx 14rpx;
  font-size: 22rpx;
}

.asset-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ece5d9;
}

.asset-row:last-child {
  border-bottom: none;
}

.asset-title {
  font-size: 28rpx;
}

.asset-meta {
  font-size: 22rpx;
  color: #7f7a6f;
  margin-top: 8rpx;
}
