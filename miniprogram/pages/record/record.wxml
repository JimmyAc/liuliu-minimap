<view class="page-shell" wx:if="{{theme && draft}}">
  <view class="theme-card" style="padding: 28rpx; margin-bottom: 24rpx; border-top: 10rpx solid {{theme.vibeColor || '#5a5a40'}};">
    <view style="font-size: 38rpx; font-weight: 600; margin-bottom: 14rpx;">{{theme.title}}</view>
    <view style="color: #6f6a5f; line-height: 1.7; margin-bottom: 16rpx;">{{theme.description}}</view>
    <view class="meta-row">
      <view class="meta-pill">{{draft.locationName}}</view>
      <view class="meta-pill">{{draft.locationContext}}</view>
    </view>
  </view>

  <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
    <view class="section-title">任务打卡</view>
    <mission-list missions="{{theme.missions}}" activeMission="{{activeMission}}" completedMissions="{{draft.completedMissions}}" missionReviews="{{draft.missionReviews}}" bind:select="selectMission" bind:verify="handleMissionVerify" />
  </view>

  <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
    <view class="section-title">当前核验任务</view>
    <view class="meta-row" style="margin-bottom: 16rpx;">
      <view class="meta-pill">{{activeMission || '未选择任务'}}</view>
      <view class="meta-pill">{{draft.walkMode === 'advanced' ? '进阶模式' : '纯粹模式'}}</view>
    </view>
    <view style="font-size: 24rpx; color: #6f6a5f; line-height: 1.7; margin-bottom: 20rpx;">上传图片并填写简短备注后，AI 会宽松判断是否完成任务，无论通过与否都会返回一句评价。</view>
    <button class="primary-btn" bindtap="verifyActiveMission" loading="{{isVerifyingMission}}">核验当前任务</button>
  </view>

  <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
    <view class="section-title">地图与轨迹</view>
    <map
      longitude="{{draft.longitude || 116.39747}}"
      latitude="{{draft.latitude || 39.908823}}"
      scale="15"
      show-location
      polyline="{{[{ points: draft.routePoints, color: '#5a5a40', width: 4 }]}}"
      style="width: 100%; height: 360rpx; border-radius: 22rpx; overflow: hidden;"
    />
    <view class="meta-row" style="margin: 20rpx 0;">
      <view class="meta-pill">{{draft.routePoints.length}} 个轨迹点</view>
      <view class="meta-pill">{{isTracking ? '追踪中' : '未追踪'}}</view>
    </view>
    <button class="ghost-btn" bindtap="toggleTracking">{{isTracking ? '停止轨迹记录' : '开始轨迹记录'}}</button>
  </view>

  <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
    <view class="section-title">图片记录</view>
    <view style="font-size: 24rpx; color: #6f6a5f; margin-bottom: 16rpx;">支持一次多选，当前素材会用于当前任务的 AI 核验与整次漫步记录。</view>
    <button class="ghost-btn" bindtap="choosePhoto" style="margin-bottom: 20rpx;">拍照或从相册多选</button>
    <scroll-view scroll-x>
      <view style="display: flex; gap: 16rpx;">
        <view wx:for="{{draft.photoList}}" wx:key="index" style="position: relative;">
          <image src="{{item}}" mode="aspectFill" style="width: 180rpx; height: 180rpx; border-radius: 20rpx;" />
          <view class="danger-btn" bindtap="removePhoto" data-index="{{index}}" style="position: absolute; top: 8rpx; right: 8rpx; padding: 10rpx 14rpx; font-size: 22rpx;">删</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
    <view class="section-title">文字记录</view>
    <textarea class="text-area" placeholder="补充当前任务的备注、你的观察，或让 AI 更容易理解这组照片..." value="{{draft.noteText}}" bindinput="handleNoteInput" maxlength="300" />
  </view>

  <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
    <checkbox-group bindchange="handleVisibilityChange">
      <label style="display: flex; align-items: center; gap: 16rpx;">
        <checkbox value="public" checked="{{draft.isPublic}}" color="#5a5a40" />
        <view>公开到社区</view>
      </label>
    </checkbox-group>
  </view>

  <button class="primary-btn" bindtap="handleSave" loading="{{isSaving}}">保存本次漫步</button>
</view>

<view wx:else class="page-shell empty-copy">还没有选定主题，请先返回探索页生成。</view>
