<view class="page-shell explore-page">
  <view class="hero-card explore-hero">
    <view class="mode-switch">
      <view class="mode-chip {{walkMode === 'pure' ? 'mode-chip-active' : ''}}" bindtap="setOption" data-field="walkMode" data-value="pure">纯粹</view>
      <view class="mode-chip {{walkMode === 'advanced' ? 'mode-chip-active' : ''}}" bindtap="setOption" data-field="walkMode" data-value="advanced">进阶</view>
    </view>
    <view class="search-panel">
      <input class="search-input" placeholder="搜索街区、地标或附近地点" value="{{searchKeyword}}" bindinput="handleSearchInput" confirm-type="search" bindconfirm="searchLocation" />
      <button class="ghost-btn search-btn" bindtap="searchLocation" loading="{{loadingSearch}}">搜索</button>
    </view>
    <view class="meta-row" style="margin-top: 18rpx;">
      <view class="meta-pill">{{locationName}}</view>
      <view class="meta-pill">{{walkMode === 'advanced' ? '3 个任务' : '1 个任务'}}</view>
      <view class="meta-pill">微信 `map` + 高德 SDK</view>
    </view>
    <view wx:if="{{searchResults.length}}" class="search-result-list">
      <view wx:for="{{searchResults}}" wx:key="id" class="search-result-item" bindtap="chooseSearchResult" data-index="{{index}}">
        <view class="search-result-name">{{item.name}}</view>
        <view class="search-result-address">{{item.address || '点击使用这个地点'}}</view>
      </view>
    </view>
  </view>

  <view class="section-card location-card">
    <view class="section-heading">
      <view>
        <view class="section-title">探索地点</view>
        <view class="section-subtitle">{{locationContext}}</view>
      </view>
      <view class="meta-pill">{{displayTag}}</view>
    </view>
    <view class="location-address">{{locationAddress || '优先基于 3km 范围地点语境生成任务，减少 AI 幻觉。'}}</view>
    <view class="action-row">
      <button class="ghost-btn" bindtap="useCurrentLocation">当前位置</button>
      <button class="ghost-btn" bindtap="handleChooseLocation">地图选点</button>
    </view>
  </view>

  <theme-card theme="{{currentTheme}}" modeLabel="{{walkMode === 'advanced' ? '进阶模式' : '纯粹模式'}}" displaySummary="{{displaySummary}}" bind:start="handleStartWalk" />

  <view class="section-card">
    <view class="section-title">{{walkMode === 'advanced' ? '进阶条件' : '纯粹主题'}}</view>
    <view wx:if="{{walkMode === 'pure'}}">
      <view class="section-subtitle" style="margin-bottom: 20rpx;">从 5 个方向里随机一个，或主动选择 1-2 个主题。</view>
      <view class="pill-row" style="margin-bottom: 20rpx;">
        <view wx:for="{{combineOptionViews}}" wx:key="label" class="{{item.active ? 'pill-active' : 'pill'}}" bindtap="toggleCombineSelection" data-value="{{item.label}}">{{item.label}}</view>
      </view>
      <view class="action-row">
        <button class="ghost-btn" bindtap="handleRandomTheme" loading="{{isGenerating}}">随机主题</button>
        <button class="primary-btn" bindtap="handleCombinedTheme" loading="{{isCombining}}">选择生成</button>
      </view>
    </view>

    <view wx:else>
      <view class="field-label">天气</view>
      <view class="pill-row" style="margin-bottom: 20rpx;">
        <view wx:for="{{weatherOptions}}" wx:key="item" class="{{weather === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="weather" data-value="{{item}}">{{item}}</view>
      </view>
      <view class="field-label">季节</view>
      <view class="pill-row" style="margin-bottom: 20rpx;">
        <view wx:for="{{seasonOptions}}" wx:key="item" class="{{season === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="season" data-value="{{item}}">{{item}}</view>
      </view>
      <view class="field-label">状态</view>
      <view class="pill-row" style="margin-bottom: 20rpx;">
        <view wx:for="{{moodOptions}}" wx:key="item" class="{{mood === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="mood" data-value="{{item}}">{{item}}</view>
      </view>
      <view class="field-label">偏好</view>
      <view class="pill-row">
        <view wx:for="{{preferenceOptions}}" wx:key="item" class="{{preference === item ? 'pill-active' : 'pill'}}" bindtap="setOption" data-field="preference" data-value="{{item}}">{{item}}</view>
      </view>
    </view>
  </view>

  <button wx:if="{{walkMode === 'advanced'}}" class="primary-btn full-width-btn" bindtap="handleGenerateTheme" loading="{{isGenerating}}">AI 生成今日进阶任务</button>
</view>
