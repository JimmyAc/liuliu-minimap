.block {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.search-row,
.action-row {
  display: flex;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  min-height: 84rpx;
  background: #fff;
  border-radius: 999rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
}

.small-btn {
  min-width: 144rpx;
}

.action-row button {
  flex: 1;
}

.poi-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ece5d9;
}

.poi-item:last-child {
  border-bottom: none;
}

.poi-name {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.poi-address {
  font-size: 24rpx;
  color: #7f7a6f;
  line-height: 1.6;
}
