<view class="page-shell">
  <view class="hero-card block">
    <view class="section-title">地图调试</view>
    <view class="section-subtitle">用微信官方 `map` 负责展示与交互，用高德 SDK 负责搜索建议、逆地理和路线规划。</view>
    <view class="meta-row" style="margin-top: 16rpx;">
      <view class="meta-pill">{{keyReady ? '高德 Key 已配置' : '高德 Key 未配置'}}</view>
      <view class="meta-pill">3km 范围测试</view>
    </view>
  </view>

  <view class="section-card block">
    <view class="search-row">
      <input class="search-input" placeholder="输入地标、街区或店铺名" value="{{searchKeyword}}" bindinput="setSearchKeyword" confirm-type="search" bindconfirm="searchTips" />
      <button class="ghost-btn small-btn" bindtap="searchTips">搜索</button>
    </view>
    <view class="action-row" style="margin-top: 16rpx;">
      <button class="ghost-btn" bindtap="useCurrentLocation">获取当前位置</button>
      <button class="primary-btn" bindtap="planWalkingRoute">测试步行路线</button>
    </view>
  </view>

  <view class="section-card block">
    <view class="section-title">地图</view>
    <view class="section-subtitle">{{locationName}} · {{locationDesc}}</view>
    <map
      id="citywalk-map"
      longitude="{{longitude}}"
      latitude="{{latitude}}"
      scale="{{scale}}"
      show-location
      markers="{{markers}}"
      circles="{{circles}}"
      polyline="{{polyline}}"
      bindmarkertap="markerTap"
      bindregionchange="regionChange"
      style="width: 100%; height: 760rpx; border-radius: 24rpx; overflow: hidden; margin-top: 20rpx;"
    />
  </view>

  <view class="section-card block">
    <view class="section-title">搜索 / 周边结果</view>
    <view wx:if="{{searchResults.length}}">
      <view wx:for="{{searchResults}}" wx:key="index" class="poi-item" bindtap="choosePoi" data-index="{{index}}">
        <view class="poi-name">{{item.name}}</view>
        <view class="poi-address">{{item.address || '无详细地址'}}</view>
      </view>
    </view>
    <view wx:else class="empty-copy" style="padding: 28rpx 0;">先点击“获取当前位置”或输入关键词搜索。</view>
  </view>
</view>
