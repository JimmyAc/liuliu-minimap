<view class="page-shell">
  <view class="hero-card" style="padding: 32rpx; margin-bottom: 24rpx;">
    <view class="section-title">我的账户</view>
    <view class="section-subtitle">先完成微信资料同步，再保存漫步记录到云端。</view>
  </view>

  <view wx:if="{{user}}" class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
    <view style="display: flex; align-items: center; gap: 20rpx; margin-bottom: 18rpx;">
      <image src="{{user.avatarUrl}}" style="width: 96rpx; height: 96rpx; border-radius: 50%; background: #ede8de;" />
      <view>
        <view style="font-size: 34rpx; font-weight: 600;">{{user.nickName}}</view>
        <view style="font-size: 24rpx; color: #7f7a6f;">{{user.openid || user._id}}</view>
      </view>
    </view>
    <view class="meta-row">
      <view class="meta-pill">角色：{{user.role || 'user'}}</view>
      <view class="meta-pill">已同步</view>
    </view>
  </view>

  <button wx:if="{{!user}}" class="primary-btn" bindtap="handleLogin" loading="{{syncing}}" style="margin-bottom: 24rpx;">微信登录并同步资料</button>

  <view class="section-card" style="padding: 28rpx; margin-bottom: 24rpx;">
    <view class="section-title">当前 MVP 能力</view>
    <view class="mission-card" style="padding: 20rpx; margin-bottom: 12rpx;">AI 主题生成</view>
    <view class="mission-card" style="padding: 20rpx; margin-bottom: 12rpx;">图片 + 文字 + 轨迹记录</view>
    <view class="mission-card" style="padding: 20rpx; margin-bottom: 12rpx;">足迹保存与社区公开</view>
  </view>

  <button class="ghost-btn" bindtap="clearDraft">清空本地漫步草稿</button>
</view>
