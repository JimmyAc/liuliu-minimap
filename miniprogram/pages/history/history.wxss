.history-hero,
.history-tabs,
.history-placeholder {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.mode-switch {
  display: inline-flex;
  background: rgba(90, 90, 64, 0.08);
  border-radius: 999rpx;
  padding: 8rpx;
}

.mode-chip {
  padding: 16rpx 34rpx;
  border-radius: 999rpx;
  color: #6f6a5f;
  font-size: 26rpx;
}

.mode-chip-active {
  background: #5a5a40;
  color: #fff;
}
